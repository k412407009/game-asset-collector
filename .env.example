# game-asset-collector 推荐本地环境变量模板
#
# 用法：
#   cp .env.example .env
#
# 说明：
# - 当前仓库独立使用时，最推荐在仓库根目录自己放一份 `.env`
# - 如果三仓放在同级目录，采集器也会回退读取 `../game-ppt-master/.env`
#   `../ppt-master/.env` `../game-review/.env`
# - 团队对外统一建议使用全大写键名，避免排障时误判

# 网页抓取兜底（App Store / Google Play 结构化抓取不完整时使用）
TAVILY_API_KEY=

# 视觉打标 + 中文画面描述
ARK_API_KEY=

# 如果你团队习惯直接用火山引擎兼容 key，也可以只填这个
# VOLCENGINE_API_KEY=

# 可选：默认输出目录。不填就落到仓库内的 game_assets_library/
# GAME_ASSET_COLLECTOR_DEFAULT_OUT=
